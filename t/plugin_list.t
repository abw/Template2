#============================================================= -*-perl-*-
#
# t/plugin_list.t
#
# Tests for the Template::Plugin::List module.
#
#========================================================================

use strict;
use warnings;
use lib qw( ./lib ../lib );
use Template::Test;

$Template::Test::DEBUG = 0;

test_expect(\*DATA);

__DATA__

#------------------------------------------------------------------------
# construction and basic access
#------------------------------------------------------------------------
-- test --
[% USE List([10, 20, 30]) -%]
size: [% List.size %]
max: [% List.max %]
item0: [% List.item(0) %]
item1: [% List.item(1) %]
-- expect --
size: 3
max: 2
item0: 10
item1: 20

-- test --
[% USE List([10, 20, 30]) -%]
[% List.text %]
-- expect --
10, 20, 30

-- test --
[% USE l = List([1, 2, 3], joint => ' - ') -%]
[% l.text %]
-- expect --
1 - 2 - 3

#------------------------------------------------------------------------
# push and unshift (GH #359)
#------------------------------------------------------------------------
-- test --
[% USE l = List([1, 2]) -%]
[% CALL l.push(3) -%]
[% l.text %]
-- expect --
1, 2, 3

-- test --
[% USE l = List([2, 3]) -%]
[% CALL l.unshift(1) -%]
[% l.text %]
-- expect --
1, 2, 3

#------------------------------------------------------------------------
# pop and shift
#------------------------------------------------------------------------
-- test --
[% USE l = List([1, 2, 3]) -%]
[% CALL l.pop -%]
[% l.text %]
-- expect --
1, 2

-- test --
[% USE l = List([1, 2, 3]) -%]
[% CALL l.shift -%]
[% l.text %]
-- expect --
2, 3

#------------------------------------------------------------------------
# copy
#------------------------------------------------------------------------
-- test --
[% USE l = List([5, 10, 15]) -%]
[% c = l.copy -%]
[% c.text %]
-- expect --
5, 10, 15

#------------------------------------------------------------------------
# list method returns array ref
#------------------------------------------------------------------------
-- test --
[% USE l = List(['a', 'b', 'c']) -%]
[% FOR item IN l.list -%]
[% item %]
[% END -%]
-- expect --
a
b
c
